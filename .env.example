# DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/sistema_contable"

# NEXT AUTH
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key"

# OBJECT STORAGE (S3 / MINIO)
