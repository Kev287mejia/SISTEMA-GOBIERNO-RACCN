generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String                  @id @default(cuid())
  email                     String                  @unique
  password                  String
  nombre                    String
  apellido                  String?
  activo                    Boolean                 @default(true)
  role                      Role
  deletedAt                 DateTime?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt
  cargo                     String?
  cedula                    String?
  departamento              String?
  failedLoginAttempts       Int                     @default(0)
  lastLoginAt               DateTime?
  lockedUntil               DateTime?
  passwordChangedAt         DateTime?
  twoFactorBackupCodes      String[]                @default([])
  twoFactorEnabled          Boolean                 @default(false)
  twoFactorSecret           String?
  deniedModules             String[]                @default([])
  sessionVersion            Int                     @default(1)
  approvedEntries           AccountingEntry[]       @relation("EntryApprover")
  createdEntries            AccountingEntry[]       @relation("EntryCreator")
  accountingObservations    AccountingObservation[]
  accounts                  Account[]
  auditLogs                 AuditLog[]
  budgetExecutions          BudgetExecution[]
  approvedBudgets           BudgetItem[]            @relation("BudgetApprover")
  createdBudgets            BudgetItem[]            @relation("BudgetCreator")
  cashClosures              CashClosure[]
  cashMovements             CashMovement[]
  checks                    Check[]
  hrRecords                 HRRecord[]
  inventoryItemsCreated     InventoryItem[]         @relation("InventoryCreator")
  inventoryRecords          InventoryTransaction[]
  notifications             Notification[]
  payrolls                  Payroll[]
  auditsRealized            PettyCashAudit[]
  pettyCashMovementsCreated PettyCashMovement[]     @relation("PettyCashMovementCreator")
  pettyCashesResponsible    PettyCash[]             @relation("PettyCashResponsible")
  bankReconciliations       BankReconciliation[]
  
  // Workflow Audit Relations
  budgetApprovedChecks    Check[] @relation("BudgetApprovedChecks")
  budgetRejectedChecks    Check[] @relation("BudgetRejectedChecks")
  preCheckApprovedChecks  Check[] @relation("PreCheckApprovedChecks")
  preCheckRejectedChecks  Check[] @relation("PreCheckRejectedChecks")
  paidChecks              Check[] @relation("CheckPaidBy")
  accountedChecks         Check[] @relation("CheckAccountedBy")
  issuedChecks            Check[] @relation("CheckIssuedBy")
  accountingClosures      AccountingClosure[]
  
  sessions                  Session[]

  @@index([email])
  @@index([role])
  @@index([activo])
  @@index([deletedAt])
  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model AccountingEntry {
  id                    String                  @id @default(cuid())
  numero                String                  @unique
  tipo                  EntryType
  fecha                 DateTime
  descripcion           String
  monto                 Decimal                 @db.Decimal(15, 2)
  estado                EntryStatus             @default(BORRADOR)
  institucion           Institution
  cuentaContable        String
  centroCosto           String?
  proyecto              String?
  documentoRef          String?
  observaciones         String?
  creadoPorId           String
  aprobadoPorId         String?
  deletedAt             DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  evidenciaUrls         String[]                @default([])
  aprobadoPor           User?                   @relation("EntryApprover", fields: [aprobadoPorId], references: [id])
  creadoPor             User                    @relation("EntryCreator", fields: [creadoPorId], references: [id])
  observations          AccountingObservation[]
  check                 Check?
  inventoryTransactions InventoryTransaction[]
  pettyCashMovement     PettyCashMovement?
  budgetItemId          String?
  budgetItem            BudgetItem?             @relation("BudgetToEntry", fields: [budgetItemId], references: [id])
  renglonGasto          String?

  @@index([numero])
  @@index([tipo])
  @@index([fecha])
  @@index([estado])
  @@index([institucion])
  @@index([cuentaContable])
  @@index([creadoPorId])
  @@index([deletedAt])
  @@index([institucion, deletedAt, tipo])
  @@index([cuentaContable, tipo, estado])
  @@index([estado, deletedAt])
  @@map("accounting_entries")
}

model BudgetItem {
  id              String            @id @default(cuid())
  codigo          String            @unique
  nombre          String
  descripcion     String?
  categoria       String
  anio            Int
  montoAsignado   Decimal           @db.Decimal(15, 2)
  montoEjecutado  Decimal           @default(0) @db.Decimal(15, 2)
  montoDisponible Decimal           @db.Decimal(15, 2)
  estado          BudgetStatus      @default(PLANIFICADO)
  tipoGasto       BudgetType        @default(FUNCIONAMIENTO)
  centroRegional  RegionalCenter    @default(BILWI)
  fechaInicio     DateTime?
  fechaFin        DateTime?
  creadoPorId     String
  aprobadoPorId   String?
  deletedAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  executions      BudgetExecution[]
  checks          Check[]
  accountingEntries AccountingEntry[] @relation("BudgetToEntry")
  aprobadoPor     User?             @relation("BudgetApprover", fields: [aprobadoPorId], references: [id])
  creadoPor       User              @relation("BudgetCreator", fields: [creadoPorId], references: [id])

  @@index([codigo])
  @@index([categoria])
  @@index([anio])
  @@index([estado])
  @@index([tipoGasto])
  @@index([centroRegional])
  @@index([creadoPorId])
  @@index([deletedAt])
  @@map("budget_items")
}

model BudgetExecution {
  id           String     @id @default(cuid())
  budgetItemId String
  monto        Decimal    @db.Decimal(15, 2)
  mes          Int
  fecha        DateTime   @default(now())
  descripcion  String
  referencia   String?
  centroCosto  String?
  usuarioId    String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  budgetItem   BudgetItem @relation(fields: [budgetItemId], references: [id])
  usuario      User       @relation(fields: [usuarioId], references: [id])

  @@index([budgetItemId])
  @@index([mes])
  @@index([usuarioId])
  @@map("budget_executions")
}

model InventoryItem {
  id            String                 @id @default(cuid())
  codigo        String                 @unique
  nombre        String
  descripcion   String?
  unidadMedida  String
  categoria     String
  stockMinimo   Decimal                @default(0) @db.Decimal(10, 2)
  stockMaximo   Decimal?               @db.Decimal(10, 2)
  stockActual   Decimal                @default(0) @db.Decimal(10, 2)
  costoUnitario Decimal                @default(0) @db.Decimal(15, 2)
  metodoKardex  String                 @default("FIFO")
  activo        Boolean                @default(true)
  deletedAt     DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  creadoPorId   String?
  creadoPor     User?                  @relation("InventoryCreator", fields: [creadoPorId], references: [id])
  transacciones InventoryTransaction[]

  @@index([codigo])
  @@index([categoria])
  @@index([activo])
  @@index([creadoPorId])
  @@index([deletedAt])
  @@map("inventory_items")
}

model InventoryTransaction {
  id                String                   @id @default(cuid())
  tipo              InventoryTransactionType
  cantidad          Decimal                  @db.Decimal(10, 2)
  costoUnitario     Decimal                  @db.Decimal(15, 2)
  costoTotal        Decimal                  @db.Decimal(15, 2)
  fecha             DateTime                 @default(now())
  numeroDocumento   String?
  comprobanteUrl    String?
  observaciones     String?
  itemId            String
  usuarioId         String
  accountingEntryId String?
  deletedAt         DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  accountingEntry   AccountingEntry?         @relation(fields: [accountingEntryId], references: [id])
  item              InventoryItem            @relation(fields: [itemId], references: [id])
  usuario           User                     @relation(fields: [usuarioId], references: [id])

  @@index([itemId])
  @@index([tipo])
  @@index([fecha])
  @@index([usuarioId])
  @@index([accountingEntryId])
  @@index([deletedAt])
  @@map("inventory_transactions")
}

model Employee {
  id                 String        @id @default(cuid())
  codigo             String?       @unique
  nombre             String
  apellido           String
  cedula             String        @unique
  email              String?
  telefono           String?
  direccion          String?
  fechaNacimiento    DateTime?
  genero             String?
  estadoCivil        String?
  fechaIngreso       DateTime
  estado             String        @default("ACTIVO")
  tipoSangre         String?
  banco              String?
  tipoCuenta         String?
  numeroCuenta       String?
  deletedAt          DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  contactoEmergencia String?
  hijos              Int?          @default(0)
  inss               String?       @unique
  nivelAcademico     String?
  profesion          String?
  ruc                String?       @unique
  telefonoEmergencia String?
  contratos          Contract[]
  hrRecords          HRRecord[]
  payrollItems       PayrollItem[]

  @@index([cedula])
  @@index([estado])
  @@index([deletedAt])
  @@map("employees")
}

model Position {
  id           String     @id @default(cuid())
  titulo       String
  descripcion  String?
  departamento String
  salarioMin   Decimal?   @db.Decimal(15, 2)
  salarioMax   Decimal?   @db.Decimal(15, 2)
  activo       Boolean    @default(true)
  deletedAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  contratos    Contract[]

  @@map("positions")
}

model Contract {
  id            String    @id @default(cuid())
  tipo          String
  salarioBase   Decimal   @db.Decimal(15, 2)
  fechaInicio   DateTime
  fechaFin      DateTime?
  estado        String    @default("ACTIVO")
  documentoUrl  String?
  observaciones String?
  empleadoId    String
  cargoId       String
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  cargo         Position  @relation(fields: [cargoId], references: [id])
  empleado      Employee  @relation(fields: [empleadoId], references: [id])

  @@index([empleadoId])
  @@index([estado])
  @@map("contracts")
}

model HRRecord {
  id             String       @id @default(cuid())
  tipo           HRRecordType
  fecha          DateTime
  descripcion    String
  empleadoId     String?
  empleadoNombre String?
  empleadoCedula String?
  cargo          String?
  departamento   String?
  salario        Decimal?     @db.Decimal(15, 2)
  fechaInicio    DateTime?
  fechaFin       DateTime?
  estado         String       @default("ACTIVO")
  documentos     String?
  observaciones  String?
  creadoPorId    String
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  creadoPor      User         @relation(fields: [creadoPorId], references: [id])
  empleado       Employee?    @relation(fields: [empleadoId], references: [id])

  @@index([tipo])
  @@index([fecha])
  @@index([empleadoId])
  @@index([empleadoCedula])
  @@index([estado])
  @@index([creadoPorId])
  @@index([deletedAt])
  @@map("hr_records")
}

model AuditLog {
  id              String      @id @default(cuid())
  accion          AuditAction
  entidad         String
  entidadId       String
  descripcion     String
  datosAnteriores Json?
  datosNuevos     Json?
  ipAddress       String?
  userAgent       String?
  fecha           DateTime    @default(now())
  usuarioId       String
  usuario         User        @relation(fields: [usuarioId], references: [id])

  @@index([accion])
  @@index([entidad])
  @@index([entidadId])
  @@index([usuarioId])
  @@index([fecha])
  @@map("audit_logs")
}

model AccountingObservation {
  id                String          @id @default(cuid())
  asientoContableId String
  observacion       String
  tipo              String          @default("COMENTARIO")
  estado            String          @default("PENDIENTE")
  creadoPorId       String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  asientoContable   AccountingEntry @relation(fields: [asientoContableId], references: [id])
  creadoPor         User            @relation(fields: [creadoPorId], references: [id])

  @@index([asientoContableId])
  @@index([creadoPorId])
  @@index([tipo])
  @@index([estado])
  @@index([createdAt])
  @@map("accounting_observations")
}

model Payroll {
  id          String        @id @default(cuid())
  mes         Int
  anio        Int
  descripcion String
  totalMonto  Decimal       @db.Decimal(15, 2)
  estado      String        @default("BORRADOR")
  fechaPago   DateTime?
  creadoPorId String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  items       PayrollItem[]
  creadoPor   User          @relation(fields: [creadoPorId], references: [id])

  @@index([mes, anio])
  @@index([estado])
  @@map("payrolls")
}

model PayrollItem {
  id             String   @id @default(cuid())
  nominaId       String
  empleadoId     String
  salarioBase    Decimal  @db.Decimal(15, 2)
  bonificaciones Decimal  @default(0) @db.Decimal(15, 2)
  deducciones    Decimal  @default(0) @db.Decimal(15, 2)
  totalNeto      Decimal  @db.Decimal(15, 2)
  detalles       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  empleado       Employee @relation(fields: [empleadoId], references: [id])
  nomina         Payroll  @relation(fields: [nominaId], references: [id])

  @@index([nominaId])
  @@index([empleadoId])
  @@map("payroll_items")
}

model PettyCash {
  id           String              @id @default(cuid())
  nombre       String              @unique
  montoInicial Decimal             @db.Decimal(15, 2)
  montoActual  Decimal             @db.Decimal(15, 2)
  estado       PettyCashStatus     @default(ACTIVA)
  usuarioId    String
  institution  Institution         @default(GOBIERNO)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  audits       PettyCashAudit[]
  movements    PettyCashMovement[]
  usuario      User                @relation("PettyCashResponsible", fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@index([estado])
  @@map("petty_cashes")
}

model PettyCashMovement {
  id                String                @id @default(cuid())
  pettyCashId       String
  tipo              PettyCashMovementType
  monto             Decimal               @db.Decimal(15, 2)
  fecha             DateTime              @default(now())
  descripcion       String
  referencia        String?
  estado            MovementStatus        @default(PENDIENTE_VALIDACION)
  usuarioId         String
  accountingEntryId String?               @unique
  inconsistente     Boolean               @default(false)
  observaciones     String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  evidenciaUrls     String[]              @default([])
  accountingEntry   AccountingEntry?      @relation(fields: [accountingEntryId], references: [id])
  pettyCash         PettyCash             @relation(fields: [pettyCashId], references: [id])
  usuario           User                  @relation("PettyCashMovementCreator", fields: [usuarioId], references: [id])

  @@index([pettyCashId])
  @@index([usuarioId])
  @@index([tipo])
  @@index([estado])
  @@map("petty_cash_movements")
}

model Entity {
  id        String     @id @default(cuid())
  nombre    String
  ruc       String?    @unique
  email     String?
  telefono  String?
  direccion String?
  contacto  String?
  tipo      EntityType @default(PROVEEDOR)
  activo    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  checks    Check[]

  @@map("entities")
}

model CashMovement {
  id            String           @id @default(cuid())
  tipo          CashMovementType
  monto         Decimal          @db.Decimal(15, 2)
  fecha         DateTime         @default(now())
  descripcion   String
  referencia    String?
  institucion   Institution      @default(GOBIERNO)
  usuarioId     String
  closureId     String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  evidenciaUrls String[]         @default([])
  closure       CashClosure?     @relation(fields: [closureId], references: [id])
  usuario       User             @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@index([closureId])
  @@index([tipo])
  @@index([fecha])
  @@map("cash_movements")
}

model Check {
  id                String           @id @default(cuid())
  numero            String           @unique
  tipo              CheckType
  banco             String
  cuentaBancaria    String
  beneficiario      String?
  monto             Decimal          @db.Decimal(15, 2)
  fecha             DateTime
  referencia        String?
  estado            CheckStatus      @default(PENDIENTE_VALIDACION)
  usuarioId         String
  accountingEntryId String?          @unique
  budgetItemId      String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  conciliado        Boolean          @default(false)
  fechaConciliacion DateTime?
  entityId          String?
  
  // Accountant Checklist
  hasCartaSolicitud    Boolean @default(false)
  hasDocumentosCompletos Boolean @default(false)
  hasFirmaSolicitante  Boolean @default(false)

  // Institutional Workflow Audit Fields
  budgetApprovedById    String?
  budgetApprovedAt      DateTime?
  budgetRejectedById    String?
  budgetRejectedAt      DateTime?
  preCheckApprovedById  String?
  preCheckApprovedAt    DateTime?
  preCheckRejectedById  String?
  preCheckRejectedAt    DateTime?
  paidById              String?
  paidAt                DateTime?
  accountedById         String?
  accountedAt           DateTime?
  issuedById            String?
  issuedAt              DateTime?
  
  renglonGasto          String?

  accountingEntry   AccountingEntry? @relation(fields: [accountingEntryId], references: [id])
  budgetItem        BudgetItem?      @relation(fields: [budgetItemId], references: [id])
  entity            Entity?          @relation(fields: [entityId], references: [id])
  usuario           User             @relation(fields: [usuarioId], references: [id])
  
  budgetApprovedBy    User? @relation("BudgetApprovedChecks", fields: [budgetApprovedById], references: [id])
  budgetRejectedBy    User? @relation("BudgetRejectedChecks", fields: [budgetRejectedById], references: [id])
  preCheckApprovedBy  User? @relation("PreCheckApprovedChecks", fields: [preCheckApprovedById], references: [id])
  preCheckRejectedBy  User? @relation("PreCheckRejectedChecks", fields: [preCheckRejectedById], references: [id])
  paidBy              User? @relation("CheckPaidBy", fields: [paidById], references: [id])
  accountedBy         User? @relation("CheckAccountedBy", fields: [accountedById], references: [id])
  issuedBy            User? @relation("CheckIssuedBy", fields: [issuedById], references: [id])

  @@index([usuarioId])
  @@index([entityId])
  @@index([budgetItemId])
  @@index([numero])
  @@index([tipo])
  @@index([estado])
  @@map("checks")
}

model CashClosure {
  id            String         @id @default(cuid())
  fechaInicio   DateTime
  fechaFin      DateTime
  montoInicial  Decimal        @db.Decimal(15, 2)
  totalIngresos Decimal        @db.Decimal(15, 2)
  totalEgresos  Decimal        @db.Decimal(15, 2)
  montoFinal    Decimal        @db.Decimal(15, 2)
  estado        ClosureStatus  @default(ABIERTO)
  usuarioId     String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  usuario       User           @relation(fields: [usuarioId], references: [id])
  movements     CashMovement[]

  @@index([usuarioId])
  @@index([estado])
  @@map("cash_closures")
}

model AccountingClosure {
  id          String   @id @default(cuid())
  mes         Int
  anio        Int
  fechaCierre DateTime @default(now())
  usuarioId   String
  usuario     User     @relation(fields: [usuarioId], references: [id])
  notas       String?
  estado      ClosureStatus @default(CERRADO)

  @@unique([mes, anio])
  @@index([mes, anio])
  @@map("accounting_closures")
}

model PettyCashAudit {
  id              String    @id @default(cuid())
  pettyCashId     String
  expectedBalance Decimal   @db.Decimal(15, 2)
  countedBalance  Decimal   @db.Decimal(15, 2)
  difference      Decimal   @db.Decimal(15, 2)
  observations    String?
  auditorId       String
  createdAt       DateTime  @default(now())
  auditor         User      @relation(fields: [auditorId], references: [id])
  pettyCash       PettyCash @relation(fields: [pettyCashId], references: [id])

  @@index([pettyCashId])
  @@index([auditorId])
  @@map("petty_cash_audits")
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  label       String
  group       String
  type        String
  description String?
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@map("system_settings")
}

model BankAccount {
  id             String            @id @default(uuid())
  bankName       String
  accountNumber  String            @unique
  accountName    String?
  accountType    String
  currency       String
  openingBalance Decimal           @db.Decimal(15, 2)
  region         String?
  costCenter     String?
  status         String            @default("PENDING_VALIDATION")
  isActive       Boolean           @default(false)
  minBalance     Decimal           @default(0) @db.Decimal(15, 2)
  currentBalance Decimal           @default(0) @db.Decimal(15, 2)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  transactions        BankTransaction[]
  reconciliations     BankReconciliation[]

  @@map("bank_accounts")
}

model BankReconciliation {
  id              String      @id @default(cuid())
  bankAccountId   String
  bankAccount     BankAccount @relation(fields: [bankAccountId], references: [id])
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  date            DateTime    @default(now())
  balanceLibros   Decimal     @db.Decimal(15, 2)
  balanceExtracto Decimal     @db.Decimal(15, 2)
  diferencia      Decimal     @db.Decimal(15, 2)
  totalMatching   Int
  periodoMes      Int
  periodoAnio      Int
  observaciones   String?
  detalles        Json?       // To store matched/unmatched summary if needed
  createdAt       DateTime    @default(now())

  @@index([bankAccountId])
  @@index([userId])
  @@index([date])
  @@map("bank_reconciliations")
}

model BankTransaction {
  id             String          @id @default(uuid())
  type           TransactionType
  amount         Decimal         @db.Decimal(15, 2)
  description    String
  reference      String?
  date           DateTime        @default(now())
  reconciled     Boolean         @default(false)
  reconciledDate DateTime?
  bankAccountId  String
  createdAt      DateTime        @default(now())
  createdBy      String
  bankAccount    BankAccount     @relation(fields: [bankAccountId], references: [id])

  @@index([bankAccountId])
  @@index([type])
  @@index([date])
  @@map("bank_transactions")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(INFO)
  title     String
  message   String
  link      String?
  read      Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
  @@index([token])
  @@map("password_reset_tokens")
}

