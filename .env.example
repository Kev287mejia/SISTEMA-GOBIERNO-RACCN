S3_ENDPOINT="" # Ejemplo MinIO: http://localhost:9000
S3_PUBLIC_URL="" # Ejemplo: https://cdn.tusistema.com o la URL de tu bucket

# EMAIL SETTINGS
MAIL_HOST=""
